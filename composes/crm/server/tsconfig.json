{
  "extends": "@projectx/config/tsconfig/server",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "types": ["bun"],
    "lib": ["ESNext"],
    "paths": {
      "@projectx/server": ["../../../apps/server/src/index.ts"],
      "@projectx/server/*": ["../../../apps/server/src/*"],
      "@projectx/crm-server": ["./src/index.ts"],
      "@projectx/crm-server/*": ["./src/*"],
      "@core": ["../../../apps/server/src/core/index.ts"],
      "@core/*": ["../../../apps/server/src/core/*"],
      "@modules/*": ["../../../apps/server/src/modules/*"],
      "@infra/*": ["../../../apps/server/src/infra/*"],
      "@db/*": ["../../../apps/server/src/infra/db/*"],
      "@db/client": ["../../../apps/server/src/infra/db/client.ts"],
      "@db/schema/*": ["../../../apps/server/src/infra/db/schema/*"],
      "@projectx/plugin-auth-server": ["../../../plugins/auth/server/src/index.ts"],
      "@projectx/plugin-auth-server/*": ["../../../plugins/auth/server/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
