{
  "extends": "@projectx/config/tsconfig/web",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@projectx/ecommerce-storefront": ["./src"],
      "@projectx/platform-web": ["../../../platform/web/src"],
      "@projectx/platform-web/*": ["../../../platform/web/src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
