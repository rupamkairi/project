{
  "extends": "@projectx/config/tsconfig/web",
  "compilerOptions": {
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@projectx/restaurant-web": ["./src"],
      "@/*": ["./src/*"],
      "@projectx/platform-web": ["../../platform/web/src"],
      "@projectx/platform-web/*": ["../../platform/web/src/*"],
      "@projectx/shared-router": ["../../../packages/router/src"],
      "@projectx/shared-router/*": ["../../../packages/router/src/*"],
      "@projectx/ui": ["../../../packages/ui/src"],
      "@projectx/ui/*": ["../../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
