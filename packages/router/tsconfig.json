{
  "extends": "@projectx/config/tsconfig/web",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@projectx/platform-web": ["./src"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/lib/**/*", "src/stores/**/*"],
  "exclude": ["node_modules", "dist", "src/routes"]
}
