{
  "name": "repo",
  "private": true,
  "workspaces": [
    "apps/*",
    "composes/*/server",
    "composes/*/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run typecheck",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules apps/*/node_modules composes/*/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "mint": "^4.2.434",
    "prettier": "^3.2.5",
    "turbo": "^2.4.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "bun@1.0.25"
}
