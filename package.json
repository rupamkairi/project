{
  "name": "repo",
  "private": true,
  "workspaces": [
    "apps/*",
    "composes/*/server",
    "composes/*/web",
    "composes/*/web/*",
    "plugins/*/server",
    "plugins/*/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run typecheck",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules composes/*/node_modules composes/*/server/node_modules composes/*/web/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11",
    "mint": "^4.2.446",
    "prettier": "^3.8.1",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.0.25",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/s3-request-presigner": "^3.1015.0",
    "drizzle-orm": "^0.45.1",
    "handlebars": "^4.7.8",
    "lucide-react": "^0.577.0",
    "nodemailer": "^8.0.3",
    "react-dropzone": "^15.0.0",
    "tailwindcss": "^4.2.2"
  }
}
