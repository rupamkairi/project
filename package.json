{
  "name": "repo",
  "private": true,
  "workspaces": [
    "apps/*",
    "composes/*/server",
    "composes/*/web",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check": "turbo run typecheck",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "rm -rf node_modules apps/*/node_modules composes/*/node_modules composes/*/server/node_modules composes/*/web/node_modules packages/*/node_modules"
  },
  "devDependencies": {
    "mint": "^4.2.437",
    "prettier": "^3.8.1",
    "turbo": "^2.8.18",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.0.25",
  "dependencies": {
    "tailwindcss": "^4.2.2"
  }
}
