<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{subject}}</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
  <div style="background: #f8f9fa; border-radius: 8px; padding: 24px; margin-bottom: 20px;">
    <h1 style="color: #1a1a1a; margin: 0 0 16px 0; font-size: 24px;">
      {{#if organizationName}}{{organizationName}}{{else}}Our Platform{{/if}}
    </h1>
    
    <p style="margin: 0 0 16px 0;">
      Hello {{#if userName}}{{userName}}{{else}}there{{/if}},
    </p>
    
    <p style="margin: 0 0 16px 0;">
      You've been invited to join our platform. Click the button below to accept the invitation:
    </p>
    
    <div style="text-align: center; margin: 24px 0;">
      <a href="{{inviteLink}}"
         style="display: inline-block; background: #2563eb; color: white; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 600;">
        Accept Invitation
      </a>
    </div>
    
    <p style="color: #666; font-size: 14px; margin: 0;">
      This invitation will expire on {{#if expiresAt}}{{date expiresAt}}{{else}}7 days{{/if}}.
    </p>
  </div>
  
  <p style="color: #999; font-size: 12px; margin: 0; text-align: center;">
    If you didn't expect this email, please ignore it.
  </p>
</body>
</html>
