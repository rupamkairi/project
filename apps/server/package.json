{
  "name": "@projectx/server",
  "version": "0.0.1",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./infra/db/client": "./src/infra/db/client.ts",
    "./infra/db/schema/identity": "./src/infra/db/schema/identity.ts",
    "./infra/db/schema/notification": "./src/infra/db/schema/notification.ts",
    "./infra/db/schema/platform": "./src/infra/db/schema/platform.ts",
    "./infra/db/seed/platform": "./src/infra/db/seed/platform.ts",
    "./infra/env": "./src/infra/env.ts",
    "./core/entity": "./src/core/entity/index.ts",
    "./modules/*": "./src/modules/*.ts",
    "./platform": "./src/platform.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "worker": "bun run src/worker.ts",
    "worker:dev": "bun run --hot src/worker.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/infra/db/seed.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "clean": "rm -rf dist node_modules",
    "docs:generate": "bun run scripts/generate-docs.ts",
    "docs:generate:skip-openapi": "bun run scripts/generate-docs.ts --skip-openapi",
    "docs:export-openapi": "bun run scripts/export-openapi.ts",
    "docs:build": "bun run docs:generate",
    "docs:watch": "bun run scripts/generate-docs.ts --watch"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/bun": "^1.3.9",
    "drizzle-kit": "^0.31.9",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@projectx/platform-server": "workspace:*",
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@neondatabase/serverless": "^1.0.2",
    "@sinclair/typebox": "^0.34.48",
    "bullmq": "^5.69.3",
    "cron": "^4.4.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "handlebars": "^4.7.8",
    "ioredis": "^5.9.3",
    "jose": "^6.1.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
